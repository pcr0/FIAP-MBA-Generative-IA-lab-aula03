# Tokens do n8n — copie este arquivo para .env e preencha com seus valores
# (.env é ignorado pelo git — NUNCA commite tokens)
#
# Como obter os tokens:
#   1. Suba o n8n: bash scripts/start_n8n.sh
#   2. Acesse http://localhost:5678
#   3. Settings → Instance-level MCP → Connection details → copie o "Access Token"
#      (esse é o N8N_MCP_TOKEN)
#   4. Settings → n8n API → Create an API key → copie a chave gerada
#      (essa é a N8N_API_KEY)

# Token JWT do MCP Server do n8n (usado pelo Claude Code via .mcp.json)
N8N_MCP_TOKEN=seu_token_mcp_aqui

# API Key do n8n REST API (usado para criar/atualizar workflows via curl)
N8N_API_KEY=sua_api_key_aqui
